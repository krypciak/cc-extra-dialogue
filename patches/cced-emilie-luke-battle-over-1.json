ain.luke", "expression": "COMPLAINING"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Oui! With that kind of distraction I'd be unfocused too."}, "person": {"person": "main.emilie", "expression": "SMILE"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Huh?"}, "person": {"person": "main.luke", "expression": "WONDERING"}}]}, {"type": "IF", "withElse": false, "condition": "call.runCount == 3", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " Hey, Luke~"}, "person": {"person": "main.emilie", "expression": "SMILE"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " I'm here."}, "person": {"person": "main.luke", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Whatcha always glancing at?"}, "person": {"person": "main.emilie", "expression": "TAUNTING"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Just checking if everything is alright."}, "person": {"person": "main.luke", "expression": "WHISTLING"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Suuuure~"}, "person": {"person": "main.emilie", "expression": "SMILE"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " ...?"}, "person": {"person": "main.lea", "expression": "SURPRISED_AWAY"}}]}, {"type": "IF", "withElse": false, "condition": "call.runCount == 4", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " Is everything alright back there?"}, "person": {"person": "main.emilie", "expression": "SMILE"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Uhm...\\. yeah, sure.\\. Everything is under control."}, "person": {"person": "main.luke", "expression": "WHISTLING"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " ...?"}, "person": {"person": "main.lea", "expression": "SURPRISED_TOWARD"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Okay-dokey, monsieur."}, "person": {"person": "main.emilie", "expression": "SMILE"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Keep watching her back."}, "person": {"person": "main.emilie", "expression": "DETERMINED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " ...?"}, "person": {"person": "main.lea", "expression": "SURPRISED_AWAY"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " ...What?"}, "person": {"person": "main.lea", "expression": "SURPRISED_TOWARD"}}]}, {"type": "IF", "withElse": false, "condition": "call.runCount == 5", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " So... What exactly happened between you two in Vermillion?"}, "person": {"person": "main.emilie", "expression": "SMILE"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " \\c[1]I have to know!"}, "person": {"person": "main.emilie", "expression": "DETERMINED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " ...?"}, "person": {"person": "main.lea", "expression": "ANNOYED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Sorry, Emilie."}, "person": {"person": "main.luke", "expression": "EYES_CLOSED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Classified information."}, "person": {"person": "main.luke", "expression": "WINK"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Come on! It's not fair to keep secrets from your friends, non?"}, "person": {"person": "main.emilie", "expression": "MOPING"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " ..."}, "person": {"person": "main.lea", "expression": "EXHAUSTED"}}]}, {"type": "IF", "withElse": false, "condition": "call.runCount == 6", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " Fine. If you won't tell me yourself..."}, "person": {"person": "main.emilie", "expression": "CULTURE"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " I will guess, until you talk."}, "person": {"person": "main.emilie", "expression": "TAUNTING"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Why?"}, "person": {"person": "main.lea", "expression": "ANNOYED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Why would I answer?"}, "person": {"person": "main.luke", "expression": "EYES_CLOSED"}}, {"type": "SHOW_SIDE_MSG