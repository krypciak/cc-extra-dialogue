{"cced-emilie-joern-battle-over-2": {"frequency": "REGULAR", "repeat": "ONCE", "condition": "party.alive.Emilie && party.alive.Joern && plot.line >= 18700 && cced.emilie-joern.battle-over-1.finished", "eventType": "PARALLEL", "runOnTrigger": [1, 2, 3], "event": [{"type": "IF", "withElse": false, "condition": "call.runCount == 1", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " How did you get into CrossWords?"}, "person": {"person": "main.emilie", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Apollo was playing it a lot."}, "person": {"person": "antagonists.sidekick", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " I wanted to see for myself, what was it all about."}, "person": {"person": "antagonists.sidekick", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " And he rolled up a \\c[3]new character\\c[0] to join you?"}, "person": {"person": "main.emilie", "expression": "CURIOUS"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Indeed."}, "person": {"person": "antagonists.sidekick", "expression": "SMILE"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Bummer! Lukas decided to show me around Rookie Harbor and then disappeared into his guild."}, "person": {"person": "main.emilie", "expression": "MOPING"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " What are they doing back there anyway?"}, "person": {"person": "main.emilie", "expression": "CURIOUS"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " ...?"}, "person": {"person": "main.lea", "expression": "THINKING"}}]}, {"type": "IF", "withElse": false, "condition": "call.runCount == 2", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " Bet all of grassheads characters were \\c[3]Spheromancers\\c[0]."}, "person": {"person": "main.emilie", "expression": "DETERMINED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " How did you figure that out?"}, "person": {"person": "antagonists.sidekick", "expression": "SARCASTIC"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " I'm a detective, Joern."}, "person": {"person": "main.emilie", "expression": "WATCH_OUT_BADASS"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Nothing goes unnoticed in my presence."}, "person": {"person": "main.emilie", "expression": "TAUNTING"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " [shakes head]"}, "person": {"person": "main.lea", "expression": "SHAKE"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Right...\\! They also looked the same."}, "person": {"person": "antagonists.sidekick", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " \\c[3]Exactly\\c[0] the same."}, "person": {"person": "antagonists.sidekick", "expression": "SARCASTIC"}}]}, {"type": "IF", "withElse": false, "condition": "call.runCount == 3", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " Playing with you is fun, Joern."}, "person": {"person": "main.emilie", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Since you watch my back, I can focus on punching them things."}, "person": {"person": "main.emilie", "expression": "DETERMINED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Thanks. I like my job."}, "person": {"person": "antagonists.sidekick", "expression": "SMILE"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Always a pleasure, when people acknowledge their tanks."}, "person": {"person": "antagonists.sidekick", "expression": "SMILE"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " You play tanks often?"}, "person": {"person": "main.emilie", "expression": "AWAY"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " I like to help other people."}, "person": {"person": "antagonists.sidekick", "expression": "UP"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Tanks are my go-to class in any RPG."}, "person": {"person": "antagonists.sidekick", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " And I