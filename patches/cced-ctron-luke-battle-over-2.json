{
  "cced-ctron-luke-battle-over-2": {
    "frequency": "REGULAR",
    "repeat": "ONCE",
    "condition": "party.alive.Glasses && party.alive.Luke && cced.ctron-luke.battle-over-1.finished && plot.line >= 40000",
    "eventType": "PARALLEL",
    "runOnTrigger": [
      1,
      2,
      3,
      4
    ],
    "event": [
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 1",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Do you think Instatainment is spying on us right now?"
            },
            "person": {
              "person": "main.glasses",
              "expression": "THOUGHTFUL"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " What do you mean?"
            },
            "person": {
              "person": "main.luke",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Evotars are a part of \\c[3]research project\\c[0]."
            },
            "person": {
              "person": "main.glasses",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " It would make sense to gather as much data as possible."
            },
            "person": {
              "person": "main.glasses",
              "expression": "EMBARRASSED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Are you saying they have \\c[3]constant surveillance\\c[0] on evotars?"
            },
            "person": {
              "person": "main.luke",
              "expression": "WONDERING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": "  Wouldn't put it past them."
            },
            "person": {
              "person": "main.glasses",
              "expression": "THOUGHTFUL"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Verdammt, from one conspiracy into another."
            },
            "person": {
              "person": "main.luke",
              "expression": "COMPLAINING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " At least Instatainment is doing it with good intentions."
            },
            "person": {
              "person": "main.glasses",
              "expression": "EMBARRASSED"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 2",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " What would be the goal of that research project?"
            },
            "person": {
              "person": "main.luke",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Doubt that watching my lazy ass will do any good to it."
            },
            "person": {
              "person": "main.luke",
              "expression": "LAUGH"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " We constantly learn new things from nature by observing it."
            },
            "person": {
              "person": "main.glasses",
              "expression": "SMILE"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " After all, it's one of the fundamental scientific methods."
            },
            "person": {
              "person": "main.glasses",
              "expression": "EMBARRASSED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Watching evotar's lives is a good start for understanding them."
            },
            "person": {
              "person": "main.glasses",
              "expression": "SMILE"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " I'm starting to feel like we live in a zoo."
            },
            "person": {
              "person": "main.luke",
              "expression": "SKEPTICAL"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " It's kind of true though."
            },
            "person": {
              "person": "main.glasses",
              "expression": "EMBARRASSED"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 3",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Wouldn't knowing that you're being watched change your behavior?"
            },
            "person": {
              "person": "main.luke",
              "expression": "EYES_CLOSED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " It's called the \\c[3]Hawthorne effect\\c[0]."
            },
            "person": {
              "person": "main.glasses",
              "expression": "SMILE"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Not much we can do about it."
            },
            "person": {
              "person": "main.glasses",
              "expression": "EMBARRASSED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Neither is it our problem."
            },
            "person": {
              "person": "main.luke",
              "expression": "LAUGH"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ..."
            },
            "person": {
              "person": "main.lea",
              "expression": "SMILE"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 4",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Lea, are you bothered by constant surveillance?"
            },
            "person": {
              "person": "main.luke",
              "expression": "WHISTLING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " [shakes head]"
            },
            "person": {
              "person": "main.lea",
              "expression": "SHAKE"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Why?"
            },
            "person": {
              "person": "main.lea",
              "expression": "SURPRISED_TOWARD"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " For once, you can't have some private time with somebody."
            },
            "person": {
              "person": "main.luke",
              "expression": "TOWARDS"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Unless you're fine with being watched."
            },
            "person": {
              "person": "main.luke",
              "expression": "WINK"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " What?"
            },
            "person": {
              "person": "main.lea",
              "expression": "ANNOYED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " What would you even do privately in CrossWorlds?"
            },
            "person": {
              "person": "main.glasses",
              "expression": "TOWARD"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Oh..."
            },
            "person": {
              "person": "main.glasses",
              "expression": "WORRIED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Forget I said anything."
            },
            "person": {
              "person": "main.luke",
              "expression": "SKEPTICAL"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ..."
            },
            "person": {
              "person": "main.lea",
              "expression": "EX2_DISAPPOINTED"
            }
          },
          {
            "type": "CHANGE_VAR_BOOL",
            "varName": "cced.ctron-luke.battle-over-2.finished",
            "value": true,
            "changeType": "set"
          }
        ]
      }
    ],
    "overrideSideMessage": false,
    "loopCount": 3,
    "type": {
      "killCount": 0,
      "type": "BATTLE_OVER"
    }
  }
}