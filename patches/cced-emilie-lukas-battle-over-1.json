{"cced-emilie-lukas-battle-over-1": {"frequency": "REGULAR", "repeat": "ONCE", "condition": "party.alive.Emilie && party.alive.Schneider && plot.line >= 40000", "eventType": "PARALLEL", "runOnTrigger": [1, 2, 3, 4, 5, 6, 7, 8], "event": [{"type": "IF", "withElse": false, "condition": "call.runCount == 1", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " Been some time since we played together."}, "person": {"person": "main.schneider", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Oui! And I'm glad that Lea is finally back!"}, "person": {"person": "main.emilie", "expression": "HAPPY"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Wait Lea?"}, "person": {"person": "main.lea", "expression": "SURPRISED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Jap. We all took a break from CrossWorlds, while you were...\\. sleeping."}, "person": {"person": "main.schneider", "expression": "EYES_CLOSED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Silly, you thought I'd play without you?"}, "person": {"person": "main.emilie", "expression": "SMILE"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Thanks..."}, "person": {"person": "main.lea", "expression": "TOUCHED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " The game was also kind of out of content for us..."}, "person": {"person": "main.schneider", "expression": "SKEPTICAL"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " But \\c[3]you\\c[0] were the main reason."}, "person": {"person": "main.schneider", "expression": "EYES_CLOSED"}}]}, {"type": "IF", "withElse": false, "condition": "call.runCount == 2", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " Honestly, waiting for news from Sergey was the worst."}, "person": {"person": "main.emilie", "expression": "EXHAUSTED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " I couldn't sleep for weeks."}, "person": {"person": "main.emilie", "expression": "SAD"}}, {"type": "SHOW_SIDE_MSG", "message": {"