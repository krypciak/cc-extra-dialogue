{
  "cced-ctron-joern-battle-over-gaia": {
    "frequency": "REGULAR",
    "repeat": "ONCE",
    "condition": "party.alive.Glasses && party.alive.Joern && area.jungle.isCurrent",
    "eventType": "PARALLEL",
    "runOnTrigger": [
      1,
      2
    ],
    "event": [
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 1",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Instatainment nailed the image of a real jungle."
            },
            "person": {
              "person": "main.glasses",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Excluding animals, of course."
            },
            "person": {
              "person": "main.glasses",
              "expression": "WORRIED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " It's very humid, lush with vegetation and full of difficult terrain."
            },
            "person": {
              "person": "main.glasses",
              "expression": "SURPRISED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Although, I'd like it to be a bit more straightforward... and smaller, I guess."
            },
            "person": {
              "person": "main.glasses",
              "expression": "EMBARRASSED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " There are no shortcuts to any place worth going, Tronny."
            },
            "person": {
              "person": "antagonists.sidekick",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ...!"
            },
            "person": {
              "person": "main.lea",
              "expression": "ASTONISHED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Yeah... you're right on that one."
            },
            "person": {
              "person": "main.glasses",
              "expression": "EMBARRASSED"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 2",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Did you know that some jungles have trees as old as two thousand years?"
            },
            "person": {
              "person": "main.glasses",
              "expression": "SMILE"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Some of them existed since when \\c[3]Terra\\c[0] was still inhabited!"
            },
            "person": {
              "person": "main.glasses",
              "expression": "AWESOME"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ...!"
            },
            "person": {
              "person": "main.lea",
              "expression": "ASTONISHED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Did you ever wonder how would it feel to live for a thousand years?"
            },
            "person": {
              "person": "antagonists.sidekick",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " As a tree, you won't feel anything at all."
            },
            "person": {
              "person": "main.glasses",
              "expression": "EMBARRASSED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " And human will probably end up desensitised to everything in a few centuries."
            },
            "person": {
              "person": "main.glasses",
              "expression": "WORRIED"
            }
          },
          {
            "type": "IF",
            "withElse": false,
            "condition": "plot.line >= 40000",
            "thenStep": [
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " What about evotars?"
                },
                "person": {
                  "person": "antagonists.sidekick",
                  "expression": "DEFAULT"
                }
              },
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " ...?"
                },
                "person": {
                  "person": "main.lea",
                  "expression": "SURPRISED_TOWARD"
                }
              },
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " Let's not think about this for now, ok?"
                },
                "person": {
                  "person": "main.glasses",
                  "expression": "EXHAUSTED"
                }
              }
            ]
          },
          {
            "type": "CHANGE_VAR_NUMBER",
            "varName": "cced.ctron-joern.tourism.locations",
            "value": 1,
            "changeType": "add"
          },
          {
            "type": "CHANGE_VAR_BOOL",
            "varName": "cced.ctron-joern.tourism.gaia",
            "value": true,
            "changeType": "set"
          }
        ]
      }
    ],
    "overrideSideMessage": false,
    "loopCount": 3,
    "type": {
      "killCount": 0,
      "type": "BATTLE_OVER"
    }
  }
}