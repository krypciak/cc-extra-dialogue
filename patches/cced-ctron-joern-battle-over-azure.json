{
  "cced-ctron-joern-battle-over-azure": {
    "frequency": "REGULAR",
    "repeat": "ONCE",
    "condition": "party.alive.Glasses && party.alive.Joern && area.beach.isCurrent",
    "eventType": "PARALLEL",
    "runOnTrigger": [
      1,
      2
    ],
    "event": [
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 1",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " This beach area is quite pretty. Now you can go on vacation too!"
            },
            "person": {
              "person": "antagonists.sidekick",
              "expression": "SMILE"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ..."
            },
            "person": {
              "person": "main.lea",
              "expression": "SMILE"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " I guess. Something is better than nothing, right?"
            },
            "person": {
              "person": "main.glasses",
              "expression": "SMILE"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " It's also way more clean than ones I've been too."
            },
            "person": {
              "person": "antagonists.sidekick",
              "expression": "TOWARD"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Can't really litter in CrossWords."
            },
            "person": {
              "person": "main.glasses",
              "expression": "EMBARRASSED"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 2",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Did you know that food leftovers from tourists are an important part of some ecosystems?"
            },
            "person": {
              "person": "main.glasses",
              "expression": "AWESOME"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Although those cases are quite rare... and don't have that many species."
            },
            "person": {
              "person": "main.glasses",
              "expression": "EMBARRASSED"
            }
          },
          {
            "type": "IF",
            "withElse": true,
            "condition": "lea.words.who",
            "thenStep": [
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " Who?"
                },
                "person": {
                  "person": "main.lea",
                  "expression": "SURPRISED_TOWARD"
                }
              }
            ],
            "elseStep": [
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " ...?"
                },
                "person": {
                  "person": "main.lea",
                  "expression": "SURPRISED_TOWARD"
                }
              }
            ]
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Mostly variations of sand crabs and worms."
            },
            "person": {
              "person": "main.glasses",
              "expression": "SMILE"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Tasty."
            },
            "person": {
              "person": "antagonists.sidekick",
              "expression": "SMILE"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ...!"
            },
            "person": {
              "person": "main.lea",
              "expression": "DISGUSTED"
            }
          },
          {
            "type": "CHANGE_VAR_NUMBER",
            "varName": "cced.ctron-joern.tourism.locations",
            "value": 1,
            "changeType": "add"
          },
          {
            "type": "CHANGE_VAR_BOOL",
            "varName": "cced.ctron-joern.tourism.azure",
            "value": true,
            "changeType": "set"
          }
        ]
      }
    ],
    "overrideSideMessage": false,
    "loopCount": 3,
    "type": {
      "killCount": 0,
      "type": "BATTLE_OVER"
    }
  }
}