{
  "cced-apollo-lukas-battle-over-1": {
    "frequency": "REGULAR",
    "repeat": "ONCE",
    "condition": "party.alive.Apollo && party.alive.Schneider && plot.line >= 40000",
    "eventType": "PARALLEL",
    "runOnTrigger": [
      1,
      2,
      3,
      4,
      5,
      6
    ],
    "event": [
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 1",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Two noble \\c[3]Spheromancers\\c[0] and a mighty \\c[3]Triblader\\c[0] join forces on the Path of Justice!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "POINTING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " A truly fearsome party!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "CONTENT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ...!"
            },
            "person": {
              "person": "main.lea",
              "expression": "PROUD"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Hold up... Spheromancer?"
            },
            "person": {
              "person": "main.schneider",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " I thought you were a Triblader!"
            },
            "person": {
              "person": "main.schneider",
              "expression": "LAUGH"
            }
          },
          {
            "type": "IF",
            "withElse": true,
            "condition": "cced.apollo.triblader",
            "thenStep": [
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " Not this again..."
                },
                "person": {
                  "person": "antagonists.fancyguy",
                  "expression": "MOPING"
                }
              }
            ],
            "elseStep": [
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " How could you possibly mistake me for a Triblader? Don't you see my crimson attire?"
                },
                "person": {
                  "person": "antagonists.fancyguy",
                  "expression": "CONTENT"
                }
              },
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " I don't know...\\! Spiky hair and all that green kinda confused me."
                },
                "person": {
                  "person": "main.schneider",
                  "expression": "UP"
                }
              },
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " You can't be serious..."
                },
                "person": {
                  "person": "antagonists.fancyguy",
                  "expression": "MOPING"
                }
              },
              {
                "type": "CHANGE_VAR_BOOL",
                "varName": "cced.apollo.triblader",
                "value": true,
                "changeType": "set"
              }
            ]
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 2",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Foes beware!\\. A party of grassheads has been spotted your location."
            },
            "person": {
              "person": "main.schneider",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Stay clear of green vegetation to avoid being ambushed."
            },
            "person": {
              "person": "main.schneider",
              "expression": "LAUGH"
            }
          },
          {
            "type": "IF",
            "withElse": true,
            "condition": "cced.apollo-lukas.battle-over-gaia.finished",
            "thenStep": [
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " Didn't you already make that joke?"
                },
                "person": {
                  "person": "antagonists.fancyguy",
                  "expression": "MOPING"
                }
              },
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " ...!"
                },
                "person": {
                  "person": "main.lea",
                  "expression": "WHISTLING"
                }
              }
            ],
            "elseStep": [
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " ..."
                },
                "person": {
                  "person": "antagonists.fancyguy",
                  "expression": "SUSPICIOUS"
                }
              }
            ]
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 3",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " In the name of Justice, we prevailed!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "POINTING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Ja! Serves them right for breaking order!"
            },
            "person": {
              "person": "main.schneider",
              "expression": "UP"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " No walking in daylight on our watch!"
            },
            "person": {
              "person": "main.schneider",
              "expression": "LAUGH"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " That's not what it means, Triblader."
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "DOWN"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " No cause can be achieved without sacrifices..."
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "LECTURING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " I hope not literal ones."
            },
            "person": {
              "person": "main.schneider",
              "expression": "LAUGH"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ...."
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "MOPING"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 4",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Justice has been served once again! But our work is far from over!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "POINTING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Hey, what's the deal with you and justice?"
            },
            "person": {
              "person": "main.schneider",
              "expression": "WONDERING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " It's simple.\\. The Path of Justice is true way to perfection."
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "CONTENT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " You didn't answer the question.\\. You just raised more."
            },
            "person": {
              "person": "main.schneider",
              "expression": "SKEPTICAL"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 5",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " I must say, this is really nice camouflage you got there."
            },
            "person": {
              "person": "main.schneider",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Even I have trouble noticing you sometimes."
            },
            "person": {
              "person": "main.schneider",
              "expression": "COMPLAINING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " It's not camouflage, Triblader."
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "ANGRY"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Then why does your head look like a flower pot?"
            },
            "person": {
              "person": "main.schneider",
              "expression": "WONDERING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Because green color is harmonic with crimson red!\\. Which is the color of \\c[3]Spheromancers\\c[0]!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "ANGRY"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Oh...\\. Ooops, my bad!"
            },
            "person": {
              "person": "main.schneider",
              "expression": "LAUGH"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ...!"
            },
            "person": {
              "person": "main.lea",
              "expression": "SMILE"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 6",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " We cut through them like a sharp blade though the grass."
            },
            "person": {
              "person": "main.schneider",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Fresh green grass."
            },
            "person": {
              "person": "main.schneider",
              "expression": "WINK"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " \\c[1]Alright, enough!!\\c[0]"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "RAGING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " To protect my honor and sense of style, I challenge you to a \\c[1]duel\\c[0], Triblader!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "POINTING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " That escalated quickly...\\. A duel?"
            },
            "person": {
              "person": "main.schneider",
              "expression": "WONDERING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Think you can take on me?"
            },
            "person": {
              "person": "main.schneider",
              "expression": "WINK"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Cut the tough act! I shall not be intimidated by that miserable display!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "SUSPICIOUS"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Do you accept my challenge?!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "SHOUTING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Fine...\\. When are we doing it?"
            },
            "person": {
              "person": "main.schneider",
              "expression": "COMPLAINING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " As soon as \\c[3]neither of us\\c[0] are required by Spheromancer Lea!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "POINTING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Your call when to \\c[3]temporarily disband our party\\c[0], Lea."
            },
            "person": {
              "person": "main.schneider",
              "expression": "SKEPTICAL"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ...Why?"
            },
            "person": {
              "person": "main.lea",
              "expression": "ANNOYED"
            }
          },
          {
            "type": "CHANGE_VAR_BOOL",
            "varName": "cced.apollo-lukas.battle-over-1.finished",
            "value": true,
            "changeType": "set"
          },
          {
            "type": "CHANGE_VAR_NUMBER",
            "varName": "ccipt.vars.Apollo-Schneider.trackDowntime",
            "value": 1,
            "changeType": "add"
          }
        ]
      }
    ],
    "overrideSideMessage": false,
    "loopCount": 3,
    "type": {
      "killCount": 0,
      "type": "BATTLE_OVER"
    }
  }
}