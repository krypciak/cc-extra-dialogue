{"cced-joern-lukas-battle-over-2": {"frequency": "REGULAR", "repeat": "ONCE", "condition": "party.alive.Joern && party.alive.Schneider && cced.joern-lukas.battle-over-1.finished && plot.line >= 40000", "eventType": "PARALLEL", "runOnTrigger": [1, 2, 3, 4, 5], "event": [{"type": "IF", "withElse": false, "condition": "call.runCount == 1", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " Isn't CrossGear connected to all five senses?"}, "person": {"person": "main.schneider", "expression": "WONDERING"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " \\c[3]Taste\\c[0] and \\c[3]smell\\c[0] are missing."}, "person": {"person": "antagonists.sidekick", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " But that's the thing, Joern."}, "person": {"person": "main.schneider", "expression": "WHISTLING"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " They are not missing, just disabled."}, "person": {"person": "main.schneider", "expression": "SKEPTICAL"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Why?"}, "person": {"person": "main.lea", "expression": "SURPRISED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Safety precaution?"}, "person": {"person": "antagonists.sidekick", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Most likely they decided that designing hedgehags taste was to much effort."}, "person": {"person": "main.schneider", "expression": "LAUGH"}}]}, {"type": "IF", "withElse": false, "condition": "call.runCount == 2", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " How do you know they are actually disabled?"}, "person": {"person": "antagonists.sidekick", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Maybe CrossGear can't physically support them."}, "person": {"person": "antagonists.sidekick", "expression": "TOWARD"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " We have \\c[3]touch\\c[0]. How different is it from taste anyway."}, "pers