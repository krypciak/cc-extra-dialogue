{
  "cced-apollo-ctron-battle-over-1": {
    "frequency": "REGULAR",
    "repeat": "ONCE",
    "condition": "party.alive.Apollo && party.alive.Glasses",
    "eventType": "PARALLEL",
    "runOnTrigger": [
      1,
      2,
      3,
      4,
      5,
      6,
      7
    ],
    "event": [
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 1",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Two noble \\c[3]Spheromancers\\c[0] and an acute \\c[3]Hexacast\\c[0] join forces on the Path of Justice!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "POINTING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Truly a sight to behold."
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "CONTENT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ...!"
            },
            "person": {
              "person": "main.lea",
              "expression": "PROUD"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Uhm...\\. path of... justice?"
            },
            "person": {
              "person": "main.glasses",
              "expression": "THOUGHTFUL"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 2",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Justice has been served once again!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "POINTING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " If you call murdering a bunch of animals justice..."
            },
            "person": {
              "person": "main.glasses",
              "expression": "WORRIED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " We must face each and every obstacle put in our way!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "DOWN"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " It is our duty as Seekers!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "POINTING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ..."
            },
            "person": {
              "person": "main.lea",
              "expression": "EXHAUSTED"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 3",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Our enemies are vanquished once again!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "POINTING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Imbued with power of the Track, they test our resolve on the path to true mastery."
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "SHOUTING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " I don't know if you can call adding guns to birds as \"imbuing power\"..."
            },
            "person": {
              "person": "main.glasses",
              "expression": "WORRIED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ..."
            },
            "person": {
              "person": "main.lea",
              "expression": "SMILE"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " But it's true, Hexacast.\\. It is the very same power that flows through seekers."
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Then why don't I have a jetpack growing on my back?"
            },
            "person": {
              "person": "main.glasses",
              "expression": "EXHAUSTED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Hmm...\\. I suppose it works differently for every creature."
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "PONDERING"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 4",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Having jetpack in CrossWords would make chest hunting less of a hussle."
            },
            "person": {
              "person": "main.glasses",
              "expression": "EMBARRASSED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ...!"
            },
            "person": {
              "person": "main.lea",
              "expression": "EXCITED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Jumping puzzles are but one of many challenges on the path to mastery!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "POINTING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Skipping them with jetpack would be nothing short of cheating!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "LECTURING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ..."
            },
            "person": {
              "person": "main.lea",
              "expression": "MOPING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " That's the point..."
            },
            "person": {
              "person": "main.glasses",
              "expression": "EXHAUSTED"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 5",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Awful lot of cybernetic enemies in CrossWorlds."
            },
            "person": {
              "person": "main.glasses",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " But they don't look like designs of the Ancients."
            },
            "person": {
              "person": "main.glasses",
              "expression": "TOWARD"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " I'm proud of your observational skills, Hexacast. You've chosen the right virtue to follow."
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "CONTENT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Some creatures are actually victims of evil experiments..."
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "LECTURING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Secretly performed by \\c[1]humans\\c[0]!"
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "POINTING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ...!"
            },
            "person": {
              "person": "main.lea",
              "expression": "ASTONISHED"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 6",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " The humans behind such experiments must be very smart."
            },
            "person": {
              "person": "main.glasses",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Cybernetics and animal uplifting are complicated concepts."
            },
            "person": {
              "person": "main.glasses",
              "expression": "SURPRISED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Not smart enough, as it seems."
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "LECTURING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " In the end, animals managed to escape from their laboratory."
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "DOWN"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " We can only theorize why and how that happened."
            },
            "person": {
              "person": "antagonists.fancyguy",
              "expression": "LECTURING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Intelligent birds with guns. What could possibly go wrong?"
            },
            "person": {
              "person": "main.glasses",
              "expression": "EMBARRASSED"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 7",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Too bad real world research into cybernetics was shut down."
            },
            "person": {
              "person": "main.glasses",
              "expression": "WORRIED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Scientists never managed to get approval from ACF."
            },
            "person": {
              "person": "main.glasses",
              "expression": "EXHAUSTED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Why?"
            },
            "person": {
              "person": "main.lea",
              "expression": "SURPRISED_AWAY"
            }
          },
          {
            "type": "IF",
            "withElse": true,
            "condition": "plot.line < 40000",
            "thenStep": [
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " Probably the same reason why they're scared of \\c[3]Artificial General Intelligence\\c[0]."
                },
                "person": {
                  "person": "main.glasses",
                  "expression": "SMILE"
                }
              },
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " They fear that non-human intelligence will go mad with power and destroy humanity."
                },
                "person": {
                  "person": "main.glasses",
                  "expression": "EMBARRASSED"
                }
              },
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " ..."
                },
                "person": {
                  "person": "main.lea",
                  "expression": "SAD"
                }
              }
            ],
            "elseStep": [
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " Probably the same reason why they're scared of \\c[3]Artificial General Intelligence\\c[0]."
                },
                "person": {
                  "person": "main.glasses",
                  "expression": "PONDERING"
                }
              },
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " They fear that non-human intelligence will go mad with power and destroy humanity."
                },
                "person": {
                  "person": "main.glasses",
                  "expression": "SAD"
                }
              },
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " ..."
                },
                "person": {
                  "person": "main.lea",
                  "expression": "SAD"
                }
              },
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " Do not falter, Spheromancer Lea! Doubt is the root of evil!"
                },
                "person": {
                  "person": "antagonists.fancyguy",
                  "expression": "LECTURING"
                }
              },
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " You are the most noble AI I've met to date!"
                },
                "person": {
                  "person": "antagonists.fancyguy",
                  "expression": "DEFAULT"
                }
              },
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " Only fools would question your true and honest nature!"
                },
                "person": {
                  "person": "antagonists.fancyguy",
                  "expression": "CONTENT"
                }
              },
              {
                "type": "SHOW_SIDE_MSG",
                "message": {
                  "en_US": " By your compassionate example, public opinion of Evotars shall undoubtedly be swayed!"
                },
                "person": {
                  "person": "antagonists.fancyguy",
                  "expression": "POINTING"
                }
              },
              {
                "type": "IF",
                "withElse": true,
                "condition": "newgame.sergey-hax",
                "thenStep": [
                  {
                    "type": "SHOW_SIDE_MSG",
                    "message": {
                      "en_US": " Uhm... are you sure about that one?"
                    },
                    "person": {
                      "person": "main.glasses",
                      "expression": "EMBARRASSED"
                    }
                  },
                  {
                    "type": "SHOW_SIDE_MSG",
                    "message": {
                      "en_US": " \\c[1]..."
                    },
                    "person": {
                      "person": "main.lea",
                      "expression": "INSANE_DOWN"
                    }
                  }
                ],
                "elseStep": [
                  {
                    "type": "IF",
                    "withElse": true,
                    "condition": "lea.words.thanks",
                    "thenStep": [
                      {
                        "type": "SHOW_SIDE_MSG",
                        "message": {
                          "en_US": " ...Thanks."
                        },
                        "person": {
                          "person": "main.lea",
                          "expression": "TOUCHED"
                        }
                      }
                    ],
                    "elseStep": [
                      {
                        "type": "SHOW_SIDE_MSG",
                        "message": {
                          "en_US": " ..."
                        },
                        "person": {
                          "person": "main.lea",
                          "expression": "TOUCHED"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "CHANGE_VAR_BOOL",
            "varName": "cced.apollo-ctron.battle-over-1.finished",
            "value": true,
            "changeType": "set"
          }
        ]
      }
    ],
    "overrideSideMessage": false,
    "loopCount": 3,
    "type": {
      "killCount": 0,
      "type": "BATTLE_OVER"
    }
  }
}