{"cced-luke-shizuka-battle-over-1": {"frequency": "REGULAR", "repeat": "ONCE", "condition": "party.alive.Luke && party.alive.Shizuka && plot.line >= 48000", "eventType": "PARALLEL", "runOnTrigger": [1, 2, 3, 4, 5, 6, 7, 8], "event": [{"type": "IF", "withElse": false, "condition": "call.runCount == 1", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " Hey, Shizuka. Are you the one, who Lea was based on?"}, "person": {"person": "main.luke", "expression": "WONDERING"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Yeah."}, "person": {"person": "main.shizuka", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " I have this strange feeling when playing with you."}, "person": {"person": "main.luke", "expression": "WORRIED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " You know... since both Lea and I are evotars..."}, "person": {"person": "main.luke", "expression": "NORM_SERIOUS"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " What do you mean?"}, "person": {"person": "main.shizuka", "expression": "DOWN"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " You two look much more different than me and Lukas."}, "person": {"person": "main.luke", "expression": "NORM_SERIOUS"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Figures. Lea had a head start of a few years."}, "person": {"person": "main.shizuka", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Don't despair. Every flower blooms in its own time."}, "person": {"person": "main.shizuka", "expression": "BRIGHT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " The first one bloomed quite nicely."}, "person": {"person": "main.luke", "expression": "EYES_CLOSED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Let's see if this one can follow."}, "person": {"person": "main.luke", "expression": "TOWARDS"}}]}, {"type": "IF", "withElse": false, "condition": "call.runCount == 2", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " A