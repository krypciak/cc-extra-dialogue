{"cced-ctron-joern-battle-over-desert": {"frequency": "REGULAR", "repeat": "ONCE", "condition": "party.alive.Glasses && party.alive.Joern && area.heat-area.isCurrent", "eventType": "PARALLEL", "runOnTrigger": [1, 2, 3, 4], "event": [{"type": "IF", "withElse": false, "condition": "call.runCount == 1", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " I don't like Maroon Valley."}, "person": {"person": "antagonists.sidekick", "expression": "ANGRY"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " It's to bright, windy and sand gets everywhere."}, "person": {"person": "antagonists.sidekick", "expression": "ANGRY"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " That's actually quite accurate climate for a midday desert."}, "person": {"person": "main.glasses", "expression": "SMILE"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Though I can see, how it can be annoying for some people."}, "person": {"person": "main.glasses", "expression": "EMBARRASSED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Lea, can we go back to Bergen?"}, "person": {"person": "antagonists.sidekick", "expression": "AWWW"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " [shakes head]"}, "person": {"person": "main.lea", "expression": "SHAKE"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " You're a little devil, you know that?"}, "person": {"person": "antagonists.sidekick", "expression": "SARCASTIC"}}, {"type": "IF", "withElse": false, "condition": "newgame.sergey-hax", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " \\c[1]Lea!"}, "person": {"person": "main.lea", "expression": "INSANE_DOWN"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " What did you expect? She went mad with power."}, "person": {"person": "main.glasses", "expression": "EMBARRASSED"}}]}]}, {"type": "IF", "withElse": false, "condition": "call.runCount == 2", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " Why is this desert so hot?"}, "person": {"person": "antagonists.sidekick", "expression": "ANGRY"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " I'm sweating buckets right now."}, "person": {"person": "antagonists.sidekick", "expression": "ANGRY"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Some folks prefer the environment to be realistic."}, "person": {"person": "main.glasses", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Otherwise they can't immerse themselves in the game."}, "person": {"person": "main.glasses", "expression": "EMBARRASSED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " There has to be a line between immersion and fun."}, "person": {"person": "antagonists.sidekick", "expression": "SARCASTIC"}}]}, {"type": "IF", "withElse": false, "condition": "call.runCount == 3", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " Seriously, how anybody can bear this heat?"}, "person": {"person": "antagonists.sidekick", "expression": "ANGRY"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Fortunately, \\c[3]personal temperature settings\\c[0] are a thing."}, "person": {"person": "main.glasses", "expression": "SMILE"}}, {"type": "IF", "withElse": false, "condition": "plot.line >= 40000", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " Evotars can't access them, but at least the defaults are somewhat nice."}, "person": {"person": "main.glasses", "expression": "EMBARRASSED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " ...!"}, "person": {"person": "main.lea", "expression": "EXHAUSTED"}}]}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " There are temperature settings?"}, "person": {"person": "antagonists.sidekick", "expression": "UP"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " ..."}, "person": {"person": "antagonists.sidekick", "expression": "SURPRISED"}}]}, {"type": "IF", "withElse": false, "condition": "call.runCount == 4", "thenStep": [{"type": "SHOW_SIDE_MSG", "message": {"en_US": " It says \\c[1]Realistic Immersion Preset\\c[0]."}, "person": {"person": "antagonists.sidekick", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Think, I'll lower it a little."}, "person": {"person": "antagonists.sidekick", "expression": "SARCASTIC"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Don't tell me you've played all this time with realistic temperature."}, "person": {"person": "main.glasses", "expression": "BLANK"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " That's like... \\c[1]40 degrees\\c[0]!"}, "person": {"person": "main.glasses", "expression": "BLANK"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " ..."}, "person": {"person": "antagonists.sidekick", "expression": "DEFAULT"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " ...!"}, "person": {"person": "main.lea", "expression": "SCARED"}}, {"type": "SHOW_SIDE_MSG", "message": {"en_US": " Oh no..."}, "person": {"person": "main.glasses", "expression": "PANIC"}}, {"type": "CHANGE_VAR_NUMBER", "varName": "cced.ctron-joern.tourism.locations", "value": 1, "changeType": "add"}, {"type": "CHANGE_VAR_BOOL", "varName": "cced.ctron-joern.tourism.desert", "value": true, "changeType": "set"}]}], "overrideSideMessage": false, "loopCount": 3, "type": {"killCount": 0, "type": "BATTLE_OVER"}}}