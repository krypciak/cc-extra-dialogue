{
  "cced-lukas-shizuka-battle-over-2": {
    "frequency": "REGULAR",
    "repeat": "ONCE",
    "condition": "party.alive.Schneider && party.alive.Shizuka && cced.lukas-shizuka.battle-over-1.finished && plot.lukeBeachDate && (cced.lukas-shizuka.battle-over-2.started || ccipt.vars.Schneider-Shizuka.maxDowntime >= 300) && plot.line >= 40000",
    "eventType": "PARALLEL",
    "runOnTrigger": [
      1,
      2,
      3,
      4,
      5,
      6,
      7,
      8
    ],
    "event": [
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 1",
        "thenStep": [
          {
            "type": "CHANGE_VAR_BOOL",
            "varName": "cced.lukas-shizuka.battle-over-2.started",
            "value": true,
            "changeType": "set"
          },
          {
            "type": "CHANGE_VAR_NUMBER",
            "varName": "ccipt.vars.Schneider-Shizuka.trackDowntime",
            "value": 1,
            "changeType": "sub"
          },
          {
            "type": "CHANGE_VAR_NUMBER",
            "varName": "ccipt.vars.Schneider-Shizuka.maxDowntime",
            "value": 0,
            "changeType": "set"
          },
          {
            "type": "CHANGE_VAR_NUMBER",
            "varName": "ccipt.vars.Schneider-Shizuka.lastDowntime",
            "value": 0,
            "changeType": "set"
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ..."
            },
            "person": {
              "person": "main.shizuka",
              "expression": "EX2_PISSED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Well... this is awkward..."
            },
            "person": {
              "person": "main.schneider",
              "expression": "WHISTLING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " It is..."
            },
            "person": {
              "person": "main.shizuka",
              "expression": "EX2_PISSED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ...?"
            },
            "person": {
              "person": "main.lea",
              "expression": "SURPRISED_TOWARD"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Why?"
            },
            "person": {
              "person": "main.lea",
              "expression": "SURPRISED_AWAY"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 2",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ..."
            },
            "person": {
              "person": "main.shizuka",
              "expression": "EX2_DISAPPOINTED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ..."
            },
            "person": {
              "person": "main.schneider",
              "expression": "WORRIED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Hi?"
            },
            "person": {
              "person": "main.lea",
              "expression": "SURPRISED_TOWARD"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ...?"
            },
            "person": {
              "person": "main.lea",
              "expression": "NERVOUS"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 3",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " So...\\! have anything to say?"
            },
            "person": {
              "person": "main.shizuka",
              "expression": "SARCASTIC"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " I'm sorry."
            },
            "person": {
              "person": "main.schneider",
              "expression": "COMPLAINING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " You should be."
            },
            "person": {
              "person": "main.shizuka",
              "expression": "EVIL_GRIN"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " I'm still shaken."
            },
            "person": {
              "person": "main.shizuka",
              "expression": "FUNNY_SMILE"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Why?"
            },
            "person": {
              "person": "main.lea",
              "expression": "SURPRISED_AWAY"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " No, you're not!"
            },
            "person": {
              "person": "main.schneider",
              "expression": "SERIOUS"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " It's me who should be shaken."
            },
            "person": {
              "person": "main.schneider",
              "expression": "PONDERING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Look, my fingers actually went numb from feedback."
            },
            "person": {
              "person": "main.shizuka",
              "expression": "DOWN"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ...?"
            },
            "person": {
              "person": "main.lea",
              "expression": "SURPRISED_TOWARD"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Therefore I'd say we're even."
            },
            "person": {
              "person": "main.shizuka",
              "expression": "FUNNY_SMILE"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 4",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " How did this thought even occur to you?"
            },
            "person": {
              "person": "main.shizuka",
              "expression": "EVIL_GRIN"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Wait, I know! It's because of Luke!"
            },
            "person": {
              "person": "main.shizuka",
              "expression": "SURPRISED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Was worth a try."
            },
            "person": {
              "person": "main.schneider",
              "expression": "SKEPTICAL"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Should've tried harder."
            },
            "person": {
              "person": "main.shizuka",
              "expression": "SARCASTIC"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " He put way more thought into it than you."
            },
            "person": {
              "person": "main.shizuka",
              "expression": "FUNNY_SMILE"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 5",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " So you're saying that...."
            },
            "person": {
              "person": "main.schneider",
              "expression": "WINK"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " No!"
            },
            "person": {
              "person": "main.shizuka",
              "expression": "ANNOYED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Alright."
            },
            "person": {
              "person": "main.schneider",
              "expression": "LAUGH"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ..."
            },
            "person": {
              "person": "main.lea",
              "expression": "ANNOYED"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " And let's never bring this topic up again."
            },
            "person": {
              "person": "main.shizuka",
              "expression": "DENYING"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Fair enough."
            },
            "person": {
              "person": "main.schneider",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " ...Why?"
            },
            "person": {
              "person": "main.lea",
              "expression": "ANNOYED"
            }
          }
        ]
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 6",
        "thenStep": []
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 7",
        "thenStep": []
      },
      {
        "type": "IF",
        "withElse": false,
        "condition": "call.runCount == 8",
        "thenStep": [
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Are you still hungry?"
            },
            "person": {
              "person": "main.schneider",
              "expression": "DEFAULT"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " Dude...\\. You're millions of light years away from me."
            },
            "person": {
              "person": "main.shizuka",
              "expression": "SARCASTIC"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " You couldn't invite me for dinner even if you wanted."
            },
            "person": {
              "person": "main.shizuka",
              "expression": "FUNNY_SMILE"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " It's not like I can't buy a ticket..."
            },
            "person": {
              "person": "main.schneider",
              "expression": "SKEPTICAL"
            }
          },
          {
            "type": "SHOW_SIDE_MSG",
            "message": {
              "en_US": " You clearly don't.\\. Now \\c[1]stop\\c[0]."
            },
            "person": {
              "person": "main.shizuka",
              "expression": "SARCASTIC"
            }
          },
          {
            "type": "CHANGE_VAR_BOOL",
            "varName": "cced.lukas-shizuka.battle-over-2.finished",
            "value": true,
            "changeType": "set"
          }
        ]
      }
    ],
    "overrideSideMessage": false,
    "loopCount": 3,
    "type": {
      "killCount": 0,
      "type": "BATTLE_OVER"
    }
  }
}